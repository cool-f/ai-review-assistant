{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ReviewerOutput",
  "type": "object",
  "required": ["task_id", "verdict", "dimensions", "blockers", "suggestions"],
  "properties": {
    "task_id": {
      "type": "string"
    },
    "verdict": {
      "type": "string",
      "enum": ["pass", "revise"]
    },
    "dimensions": {
      "type": "object",
      "properties": {
        "correctness": { "type": "string", "enum": ["pass", "revise"] },
        "security": { "type": "string", "enum": ["pass", "revise"] },
        "performance": { "type": "string", "enum": ["pass", "revise"] },
        "testability": { "type": "string", "enum": ["pass", "revise"] },
        "code_clarity": { "type": "string", "enum": ["pass", "revise"] },
        "design_quality": { "type": "string", "enum": ["pass", "revise"] },
        "craft": { "type": "string", "enum": ["pass", "revise"] },
        "functionality": { "type": "string", "enum": ["pass", "revise"] },
        "accessibility": { "type": "string", "enum": ["pass", "revise"] }
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["file", "issue", "severity", "suggestion"],
        "properties": {
          "file": { "type": "string" },
          "line": { "type": "string" },
          "issue": { "type": "string" },
          "severity": { "type": "string", "enum": ["阻塞"] },
          "suggestion": { "type": "string" }
        }
      }
    },
    "suggestions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["file", "issue", "severity", "suggestion"],
        "properties": {
          "file": { "type": "string" },
          "issue": { "type": "string" },
          "severity": { "type": "string", "enum": ["建议"] },
          "suggestion": { "type": "string" }
        }
      }
    }
  }
}
