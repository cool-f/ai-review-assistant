# ============================================
# 期末复习助手 — 环境变量模板
# 复制为 .env 后填入实际值
# ============================================

# PostgreSQL
POSTGRES_USER=review_user
POSTGRES_PASSWORD=review_pass
POSTGRES_DB=review_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# FastAPI
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
CORS_ORIGINS=http://localhost:5173

# ── AI 调用 ──────────────────────────────────────────
# 提供商: anthropic | openai | qwen | deepseek
AI_PROVIDER=

# API Keys（按需填写使用的提供商）
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DASHSCOPE_API_KEY=
DEEPSEEK_API_KEY=

# 默认模型（留空使用各提供商内置默认值）
AI_DEFAULT_MODEL=
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.7
