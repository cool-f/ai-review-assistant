# 期末复习助手：本地单用户环境变量模板
# 复制为仓库根目录的 .env，并只填写实际使用的 AI 提供商密钥。

# PostgreSQL + pgvector
POSTGRES_USER=review_user
POSTGRES_PASSWORD=review_pass
POSTGRES_DB=review_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# FastAPI
APP_HOST=0.0.0.0
APP_PORT=8000
APP_VERSION=0.2.0
DEBUG=true
CORS_ORIGINS=http://localhost:5173
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=52428800

# 文本生成：anthropic | openai | qwen | deepseek
AI_PROVIDER=deepseek
AI_DEFAULT_MODEL=deepseek-chat
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.7

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DASHSCOPE_API_KEY=
DEEPSEEK_API_KEY=

# 向量检索（当前使用 DashScope 1024 维嵌入）
EMBEDDING_PROVIDER=dashscope
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSIONS=1024
EMBEDDING_BATCH_SIZE=10

# 每日 AI Token 硬预算；达到后拒绝新的 AI 调用，0 表示不限额
DAILY_TOKEN_BUDGET=1000000

# 跨课件知识点关联阈值
LINKING_SIMILARITY_THRESHOLD=0.85
